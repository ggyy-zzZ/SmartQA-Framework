// P0-S3：替换 QaAnswerGateService.hasFlexibleCertificateEvidence 的字符串匹配逻辑。
// package 必须与 kmodule.xml#kbase@packages 一致。
package rules.qa.answer_gate

import com.qa.demo.qa.rules.fact.EvidenceFact
import com.qa.demo.qa.rules.fact.GateFact
import com.qa.demo.qa.rules.fact.QaContextFact
import com.qa.demo.qa.rules.QaQueryType

// by-schema 命中：queryType 是 cert 相关且 evidenceSchema == person_certificate_v1
rule "qa.gate.flexible-cert.by-schema"
    salience 100
    when
        $gate: GateFact(queryTypeEnum in (QaQueryType.COMPANY_CERTIFICATE, QaQueryType.PERSON_CERTIFICATE_LIST))
        $e:    EvidenceFact(evidenceSchema == "person_certificate_v1")
    then
        $gate.setAllowGenerate(true);
        update($gate);
end

// by-source-prefix 命中：柔性数据源前缀任一命中
rule "qa.gate.flexible-cert.by-source-prefix"
    salience 90
    when
        $gate: GateFact(queryTypeEnum in (QaQueryType.COMPANY_CERTIFICATE, QaQueryType.PERSON_CERTIFICATE_LIST))
        $e:    EvidenceFact(source != null,
                            (source.toLowerCase().contains("document-chunk-db")
                             || source.toLowerCase().contains("enterprise_mysql_compiled")
                             || source.toLowerCase().startsWith("mysql-structured-")
                             || source.toLowerCase().contains("neo4j-certificate-instance")))
    then
        $gate.setAllowGenerate(true);
        update($gate);
end
