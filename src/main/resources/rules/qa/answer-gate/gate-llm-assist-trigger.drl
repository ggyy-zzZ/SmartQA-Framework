// P0-S3：替换 QaAnswerGateService.allowByLlmAssist 入口前的硬判定。
// 决定在 rejectionReasons == "need_evidence_mismatch" / "query_type_evidence_mismatch"
// 时是否允许调用 LLM 兜底（避免规则短路 LLM 兜底）。
package rules.qa.answer_gate

import com.qa.demo.qa.rules.fact.GateFact
import com.qa.demo.qa.rules.fact.QaContextFact
import com.qa.demo.qa.rules.QaQueryType

rule "qa.gate.llm-assist.trigger.need-mismatch"
    salience 80
    when
        $gate: GateFact(rejectionReasons contains "need_evidence_mismatch")
    then
        // 触发条件：当前证据已经覆盖 cert/schema 之一；缺 catalog gate rule 时不进入 LLM
        if ($gate.getQueryTypeEnum() == QaQueryType.PERSON_CERTIFICATE_LIST
                || $gate.getQueryTypeEnum() == QaQueryType.COMPANY_CERTIFICATE) {
            $gate.setAllowByLlmAssist(true);
        }
        update($gate);
end

rule "qa.gate.llm-assist.trigger.query-type-mismatch"
    salience 70
    when
        $gate: GateFact(rejectionReasons contains "query_type_evidence_mismatch")
    then
        $gate.setAllowByLlmAssist(true);
        update($gate);
end
