        "deleteflagColumn": "deleteflag",
        "entityIdColumn": "id",
        "displayNameColumns": ["name"],
        "roleColumns": [],
        "enumMappings": {},
        "statusNormalization": {},
        "supplementalTables": ["company"]
      }
    ]
  },
  "correctionRules": [
    {
      "id": "company_correction",
      "description": "公司纠偏 - 用户纠正公司名称时过滤到精确匹配",
      "prefixPatterns": [
        "^不对", "^不是", "^错了", "^错啦", "^说错了",
        "^你搞错了", "^搞错了", "^纠正一下", "^更正",
        "^应该是", "^其实是", "^正确是", "^应当是"
      ],
      "entityPattern": "(?:总部|母公司|总公司|主体)(?:是|为|：|:)?\\s*([^，,。；;？?！!\\n]+(?:有限公司|有限责任公司|股份有限公司|分公司|公司))",
      "entityType": "company",
      "suffixes": [
        "有限公司",
        "有限责任公司",
        "股份有限公司",
        "分公司",
        "公司"
      ],
      "relatedKeywords": [
        "分公司", "子公司", "下属",
        "有哪些公司", "哪些主体", "分支机构"
      ]
    }
  ],
