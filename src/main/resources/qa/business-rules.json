{
  "version": 3,
  "schemaVersion": "1.0",
  "intentRules": {
    "personNamePatterns": {
      "beforeAction": [
        "([\\u4e00-\\u9fa5]{2,4})\\s*(负责|管|监管|保管|执行)"
      ],
      "beforeResign": [
        "([\\u4e00-\\u9fa5]{2,4})\\s*离职"
      ],
      "leadingName": [
        "^([\\u4e00-\\u9fa5]{2,3})(?=[，,。；;：:？?！!、\\s]|离职|负责|管|是|在|的|有)"
      ],
      "pronounBlocklist": [
        "她",
        "他",
        "它",
        "其",
        "这",
        "那",
        "谁",
        "哪",
        "啥",
        "什"
      ],
      "honorificSuffixes": [
        "先生",
