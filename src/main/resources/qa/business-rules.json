{
  "intentRules": {
    "personNamePatterns": {
      "beforeAction": [
        "([\\u4e00-\\u9fa5]{2,4})\\s*(负责|管|监管|保管|执行)"
      ],
      "beforeResign": [
        "([\\u4e00-\\u9fa5]{2,4})\\s*离职"
      ],
      "leadingName": [
        "^([\\u4e00-\\u9fa5]{2,3})(?=[，,。；;：:？?！!、\\s]|离职|负责|管|是|在|的|有)"
      ],
      "pronounBlocklist": [
        "她", "他", "它", "其", "这", "那", "谁", "哪", "啥", "什"
      ],
      "honorificSuffixes": [
        "先生", "女士", "小姐", "老师", "经理", "总监", "总裁", "董事", "总", "工"
      ]
    },
    "queryTypeConditions": [
      {
        "id": "person_role_list",
        "description": "人物角色列表查询",
        "keywords": [
          "任职", "担任", "职位", "角色", "负责", "管", "监管",
          "法人", "法定代表人", "董事", "监事", "股东", "哪些主体", "主体"
        ],
        "queryType": "person_role_list",
        "requiresPerson": true,
        "weakQueryTypes": [
          "semantic",
          "unknown",
          "mixed"
        ]
      },
      {
        "id": "person_certificate_list",
        "description": "人物证照列表查询",
        "keywords": [
          "证照", "许可证", "执照", "资质", "备案", "证书", "证",
          "负责", "管", "列出", "多少", "什么", "啥", "涉及"
        ],
        "queryType": "person_certificate_list",
        "requiresPerson": true,
        "weakQueryTypes": [
          "company_certificate",
          "company_profile",
          "semantic",
          "unknown",
          "mixed"
        ]
      },
      {
        "id": "company_certificate",
        "description": "企业证照查询",
        "keywords": [
          "证照", "许可证", "执照", "资质", "备案", "证书", "证", "印章", "公章"
        ],
        "queryType": "company_certificate",
        "requiresPerson": false,
        "weakQueryTypes": [
          "semantic",
          "unknown",
          "mixed"
        ]
      },
      {
        "id": "company_profile",
        "description": "企业概况查询",
        "keywords": [
          "总部", "母公司", "总公司", "简介", "概况", "基本情况"
        ],
        "queryType": "company_profile",
        "requiresPerson": false,
        "weakQueryTypes": [
          "semantic",
          "unknown",
          "mixed"
        ]
      },
      {
        "id": "entity_correction",
        "description": "实体纠偏查询",
        "keywords": [
          "不对", "不是", "错了", "错啦", "说错了",
          "你搞错了", "搞错了", "纠正一下", "更正",
          "应该是", "其实是", "正确是", "应当是"
        ],
        "queryType": "entity_correction",
        "requiresPerson": false
      }
    ]
  },
  "dataSources": {
    "structuredQueries": [
      {
        "id": "person_stewardship",
        "description": "人物职责查询 - 从业务库查询人员的监管/保管/执行角色",
        "table": "certificate_management",
        "deleteflagColumn": "deleteflag",
        "entityIdColumn": "id",
        "displayNameColumns": ["company_name"],
        "roleColumns": [
          {
            "column": "supervisors",
            "label": "监管人",
            "type": "comma_separated_ids"
          },
          {
            "column": "certification_keepers",
            "label": "保管人",
            "type": "comma_separated_ids"
          },
          {
            "column": "executors",
            "label": "执行人",
            "type": "comma_separated_ids"
          }
        ],
        "enumMappings": {
          "cert_type": "certificate_type"
        },
        "statusNormalization": {
          "0": "有效",
          "1": "失效",
          "有效": "有效",
          "无效": "失效",
          "失效": "失效"
        },
        "supplementalTables": ["company", "employee"]
      },
      {
        "id": "company_info",
        "description": "公司信息查询",
        "table": "company",
        "deleteflagColumn": "deleteflag",
        "entityIdColumn": "company_id",
        "displayNameColumns": ["company_name"],
        "roleColumns": [],
