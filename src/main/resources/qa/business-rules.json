  "retrievalThresholds": {
    "sourceThresholds": [
      {
        "source": "mysql-person-certificate",
        "queryType": "person_certificate_list",
        "minCount": 1,
        "description": "MySQL证照记录>=1时截断"
      },
      {
        "source": "mysql-structured-person_stewardship",
        "queryType": "person_certificate_list",
        "minCount": 1,
        "description": "配置化结构化查询返回>=1时截断"
      }
    ]
  },
  "outputContracts": {
    "default": "当证据为多条并列记录时，须列全证据中的条目，结论中的条数须与证据条数一致；仅使用证据片段里已出现的属性名与取值作答。",
    "list_query": "【输出契约 list_query】证据为多条记录时：须列全全部条目，可先给总数再列清单；结论条数与证据条数一致。",
    "structured_row": "【输出契约 structured_row】证据为结构化键值行时：按行逐条列出片段中的各属性；不得用证据未出现的维度作答；若用户追问「类型」且上下文为相关主题，仅列类型名称（可去重）。",
    "identity_resolution": "【输出契约 identity_resolution】当证据片段呈现同一实体的身份属性对照时，可据该片段回答不同称呼是否指同一实体；已有对照时勿称「证据未包含」。",
    "entity_correction": "【输出契约 entity_correction】用户在否定上一轮并给出正确主体/事实时：先简短确认纠偏（勿用「是的」附和错误前提）；仅回答用户本轮关心的维度；未明确要求时不要罗列关联主体；不得从分支状态推断主体状态。",
    "canonical_fact": "【输出契约 canonical_fact】证据来源为 canonical 时：可据片段中的属性直接作答；勿与结构化库字段矛盾；若仅有常识而无其它明细，说明「常识层已确认，详细字段需另查」。",
    "person_certificate_list": "【输出契约 person_certificate_list】证据为结构化键值行时：按行逐条列出片段中的各属性（如类型、所属组织、职责角色、状态等）；不得用证据未出现的维度作答；若用户追问「类型」且上下文为证照主题，仅列类型名称（可去重）。术语约束：证照类型是类别标签，证照是该企业在该类型下的一条实例记录；未见多条实例证据时，不要把同一企业同一类型拆成多本证照。",
    "person_role_list": "【输出契约 person_role_list】证据为多条任职/角色记录时：须列全全部主体或角色归属，可先给总数再列清单；结论条数与证据条数一致。",
    "company_certificate": "【输出契约 company_certificate】证据为公司证照记录时：须列全全部证照类型及状态；结论条数与证据条数一致。术语约束：默认按“企业+证照类型”对应一条证照实例汇总，除非证据明确显示同类型存在多条不同记录（如编号/有效期/状态不同）。",
    "company_profile": "【输出契约 company_profile】证据为公司概况时：按问句关心的维度回答；不得罗列无关属性。"
  }
}