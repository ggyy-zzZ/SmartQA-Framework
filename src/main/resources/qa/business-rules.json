  "filterFieldCoverageRules": [
    {
      "id": "establishment_date",
      "displayLabel": "成立日期",
      "questionAnyKeywords": [
        "成立时间",
        "成立日期",
        "设立日期"
      ],
      "filterIntentKeywords": [
        "有哪些",
        "超过",
