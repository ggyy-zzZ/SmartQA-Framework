        "小姐",
        "老师",
        "经理",
        "总监",
        "总裁",
        "董事",
        "总",
        "工"
      ]
    },
    "strategyInferenceConditions": []
  },
  "certificateRetrieval": {
    "personQueryConfigId": "person_stewardship",
    "companyQueryConfigId": "certificate_by_company",
    "graphInstanceSource": "neo4j-certificate-instance",
    "forbidUnscopedGlobalScan": true,
    "activeCompanyOperatingStatusCodes": [
